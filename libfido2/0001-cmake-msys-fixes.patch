From 26354fe56bcd26d379aa03710ae7723d5f374ce3 Mon Sep 17 00:00:00 2001
From: Johannes Schindelin <johannes.schindelin@gmx.de>
Date: Fri, 28 Feb 2020 13:55:16 +0100
Subject: [PATCH] cmake-msys-fixes

---
 CMakeLists.txt       | 1 +
 tools/CMakeLists.txt | 4 ++++
 2 files changed, 5 insertions(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index dc31cc0..e69901c 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -51,6 +51,7 @@ add_definitions(-D_FIDO_PATCH=${FIDO_PATCH})
 
 if(CYGWIN OR MSYS OR MINGW)
 	set(WIN32 1)
+	add_definitions(-D_BSD_SOURCE)
 endif()
 
 if(WIN32)
diff --git a/tools/CMakeLists.txt b/tools/CMakeLists.txt
index e1f4366..9d3c0c6 100644
--- a/tools/CMakeLists.txt
+++ b/tools/CMakeLists.txt
@@ -13,6 +13,10 @@ list(APPEND COMPAT_SOURCES
 	../openbsd-compat/strsep.c
 )
 
+if(MSYS)
+	set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -D_NSIG=NSIG")
+endif()
+
 if(WIN32 AND NOT CYGWIN AND NOT MSYS)
 	list(APPEND COMPAT_SOURCES
 		../openbsd-compat/bsd-getline.c
-- 
2.38.0.windows.1

